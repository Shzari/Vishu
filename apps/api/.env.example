PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
# Recommended: set a dedicated key for encrypting SMTP / platform secrets at rest.
# If omitted, the API falls back to JWT_SECRET for backward-compatible protection.
PLATFORM_SECRET_ENCRYPTION_KEY=
JWT_EXPIRES_IN=7d
# Development example:
# CORS_ORIGIN=http://localhost:3001
# APP_BASE_URL=http://localhost:3001
#
# Demo / production example:
# CORS_ORIGIN=https://vishu.shop,https://www.vishu.shop
# APP_BASE_URL=https://vishu.shop
CORS_ORIGIN=http://localhost:3001
APP_BASE_URL=http://localhost:3001
UPLOAD_DIR=uploads

DB_SERVER=localhost
DB_INSTANCE=MARKET
DB_NAME=vishu
DB_TRUSTED_CONNECTION=true
# Only needed if you turn off trusted connection
DB_USER=
DB_PASSWORD=

# Optional SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@vishu.shop

# Optional Stripe secrets for env-managed payment configuration
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SIGNING_SECRET=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SIGNING_SECRET=

# Optional Algolia product search
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX_NAME=vishu_products
